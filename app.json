{
  "expo": {
    "name": "yasa",
    "slug": "yasa",
    "scheme": "yasa",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.bonitox.yasa",
      "infoPlist": {
        "NSCameraUsageDescription": "YASA verwendet die Kamera zum Scannen von QR-Codes für den Workspace-Beitritt.",
        "NSFaceIDUsageDescription": "YASA verwendet Face ID zum Schutz des Admin-Bereichs."
      }
    },
    "android": {
      "package": "com.bonitox.yasa",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router"
    ],
    "extra": {
  "router": {},
  "supabase": {
    "url": "",
    "anonKey": "",
    "supabase_note": "Set credentials via EAS Secrets: EXPO_PUBLIC_SUPABASE_URL and EXPO_PUBLIC_SUPABASE_ANON_KEY"
  },
  "eas": {
    "projectId": "56a1de94-acba-4c5b-b00b-8a8eba4c3a95"
  }
},
    "owner": "bonitox"
  }
}
